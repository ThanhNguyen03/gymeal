# ============================================================
# Gymeal — Environment Variables Example
# ============================================================
# 1. Copy this file:  cp .example.env .env
# 2. Fill in real values for each variable below.
# 3. NEVER commit .env — only .example.env is tracked.
# 4. All Stripe keys MUST be sk_test_... / pk_test_... (sandbox only).
# ============================================================

# ── SHARED ───────────────────────────────────────────────────────────────────

# PostgreSQL (local Docker or Supabase)
# Local (docker-compose.yml defaults): postgresql://gymeal:gymeal_dev_password@localhost:5432/gymeal_db
# Supabase: https://supabase.com/dashboard → Project Settings → Database → Connection string (URI)
#           Choose "URI" format. Replace [YOUR-PASSWORD] with your DB password.
DATABASE_URL=postgresql://gymeal:gymeal_dev_password@localhost:5432/gymeal_db

# Redis (local Docker or Upstash)
# Local (docker-compose.yml defaults): redis://localhost:6379
# Upstash: https://console.upstash.com → Database → Details → copy "Redis URL" (redis://...)
REDIS_URL=redis://localhost:6379

# Internal auth shared secret — BFF (C# back-end) → Python ai-service communication.
# Generate a secure random value:
#   macOS/Linux: openssl rand -hex 32
#   Result looks like: a3f2b1c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2
INTERNAL_AUTH_SECRET=replace_with_openssl_rand_hex_32

# ── C# BACK-END (apps/back-end) ──────────────────────────────────────────────

# URL the back-end uses to call the Python ai-service (internal, NOT the public URL)
# Local: http://localhost:8001
# Koyeb production: use Koyeb internal service URL (Settings → Service → Internal URL)
AI_SERVICE_INTERNAL_URL=http://localhost:8001

# JWT RS256 keypair for access/refresh tokens
# Generate:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   cat private.pem | base64 | tr -d '\n'   → JWT_PRIVATE_KEY_BASE64
#   cat public.pem  | base64 | tr -d '\n'   → JWT_PUBLIC_KEY_BASE64
# Delete the .pem files after encoding — do not commit them.
JWT_PRIVATE_KEY_BASE64=replace_with_base64_encoded_rsa_private_key
JWT_PUBLIC_KEY_BASE64=replace_with_base64_encoded_rsa_public_key
JWT_ISSUER=gymeal
JWT_AUDIENCE=gymeal-api
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# CORS — which origin the back-end accepts requests from
# Local: http://localhost:3000
# Vercel production: https://gymeal.vercel.app  (or your custom domain)
CORS_ALLOWED_ORIGIN=http://localhost:3000

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# Sentry (C# back-end error tracking)
# Get from: https://sentry.io
#   → New Project → Platform: ASP.NET Core → copy DSN
#   DSN looks like: https://abc123@o123.ingest.sentry.io/456
BACKEND_SENTRY_DSN=https://replace@o0.ingest.sentry.io/0

# Stripe — SANDBOX/TEST MODE ONLY ($0 forever for personal projects)
# Steps:
#   1. https://dashboard.stripe.com → toggle "Test mode" ON (top-right)
#   2. Developers → API Keys:
#      - "Publishable key" (pk_test_...) → STRIPE_PUBLISHABLE_KEY
#      - "Secret key" (sk_test_...)      → STRIPE_SECRET_KEY
#   3. Developers → Webhooks → Add endpoint:
#      - URL: https://your-backend-url/api/v1/payments/webhook
#      - Events: checkout.session.completed, payment_intent.succeeded, payment_intent.payment_failed
#      - Copy "Signing secret" (whsec_...) → STRIPE_WEBHOOK_SECRET
STRIPE_SECRET_KEY=sk_test_replace_with_stripe_test_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_stripe_webhook_signing_secret
STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_stripe_test_publishable_key

# Cloudinary (meal/avatar image CDN)
# Steps:
#   1. https://console.cloudinary.com → Sign up (free tier: 25 credits/month)
#   2. Dashboard → copy Cloud Name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=replace_with_cloudinary_cloud_name
CLOUDINARY_API_KEY=replace_with_cloudinary_api_key
CLOUDINARY_API_SECRET=replace_with_cloudinary_api_secret

# ── PYTHON AI SERVICE (apps/ai-service) ──────────────────────────────────────

# Groq API key (LLM inference — 30 req/min, 6k tok/min free)
# Steps:
#   1. https://console.groq.com → Sign up
#   2. API Keys → Create API Key
#   3. Copy key (starts with gsk_...)
# Recommended model: llama3-70b-8192 (8192 token context window)
GROQ_API_KEY=gsk_replace_with_groq_api_key

# Sentry (Python ai-service error tracking)
# Get from: https://sentry.io
#   → New Project → Platform: FastAPI (Python) → copy DSN
AI_SERVICE_SENTRY_DSN=https://replace@o0.ingest.sentry.io/1

# LLM token budget — total context for llama3-70b is 8192
# MAX_CONTEXT_TOKENS + MAX_RESPONSE_TOKENS must be ≤ 8192
MAX_CONTEXT_TOKENS=3584
MAX_RESPONSE_TOKENS=512

# Cold-start recommendation threshold
# Phase 0 (0 events): rule-based only   →  goal_tags match
# Phase 1 (1-20 events): 70% rule + 30% AI
# Phase 2 (>20 events): full AI cosine similarity
COLD_START_THRESHOLD=20

# Service binding
AI_SERVICE_PORT=8001
AI_SERVICE_HOST=0.0.0.0

# ── NEXT.JS FRONT-END (apps/front-end) ───────────────────────────────────────

# Base URL of C# back-end — the ONLY API URL the front-end needs (BFF pattern)
# Local: http://localhost:5000
# Production: https://api.gymeal.app (or Koyeb public URL)
# NOTE: NEXT_PUBLIC_ prefix makes this available in browser JS bundles
NEXT_PUBLIC_API_URL=http://localhost:5000

# Sentry (Next.js front-end error tracking)
# Get from: https://sentry.io
#   → New Project → Platform: Next.js → copy DSN
NEXT_PUBLIC_SENTRY_DSN=https://replace@o0.ingest.sentry.io/2

# Logtail (structured log aggregation — Winston HTTP transport)
# Steps:
#   1. https://logtail.com → Sign up (free: 1GB/month)
#   2. Sources → New Source → HTTP → copy Source Token
LOGTAIL_SOURCE_TOKEN=replace_with_logtail_source_token

# Next.js dev server port
PORT=3000

# ============================================================
# EXTERNAL SERVICES SETUP GUIDE
# ============================================================
#
# 1. SUPABASE  (PostgreSQL + pgvector)             https://supabase.com/dashboard
#    a. Create project → choose nearest region
#    b. Settings → Database → Connection string → URI → copy as DATABASE_URL
#    c. SQL Editor → run:
#         CREATE EXTENSION IF NOT EXISTS pg_trgm;
#         CREATE EXTENSION IF NOT EXISTS vector;
#    d. Free tier: 500 MB DB, 2 active projects
#
# 2. UPSTASH REDIS                                  https://console.upstash.com
#    a. Create Database → choose region
#    b. Details tab → copy "Redis URL" → REDIS_URL
#    c. Free tier: 10 000 commands/day, 256 MB
#
# 3. GROQ  (LLM inference)                          https://console.groq.com
#    a. Sign up → API Keys → Create API Key
#    b. Copy key (gsk_...) → GROQ_API_KEY
#    c. Free tier: 30 req/min, 6 000 tok/min
#    d. Default model: llama3-70b-8192
#
# 4. SENTRY  (Error tracking — 3 projects)          https://sentry.io
#    a. Create organisation → Create 3 projects:
#       - ASP.NET Core   → BACKEND_SENTRY_DSN
#       - FastAPI/Python → AI_SERVICE_SENTRY_DSN
#       - Next.js        → NEXT_PUBLIC_SENTRY_DSN
#    b. Project → Settings → Client Keys (DSN) → copy DSN
#    c. Free tier: 5 000 errors/month
#
# 5. STRIPE  (Payments — test/sandbox forever free)  https://dashboard.stripe.com
#    a. Create account → enable Test mode (top-right toggle)
#    b. Developers → API Keys → copy Publishable + Secret keys
#    c. Developers → Webhooks → Add endpoint:
#       URL: https://<your-backend>/api/v1/payments/webhook
#       Events: checkout.session.completed
#               payment_intent.succeeded
#               payment_intent.payment_failed
#    d. Copy Signing secret (whsec_...) → STRIPE_WEBHOOK_SECRET
#
# 6. CLOUDINARY  (Image CDN)                        https://console.cloudinary.com
#    a. Sign up → Dashboard → copy Cloud Name, API Key, API Secret
#    b. Settings → Upload → Add upload preset (unsigned) for meal photos
#    c. Free tier: 25 GB storage, 25 GB bandwidth/month
#
# 7. LOGTAIL  (Log aggregation)                     https://logtail.com
#    a. Sign up → Sources → New Source → HTTP
#    b. Copy Source Token → LOGTAIL_SOURCE_TOKEN
#    c. Free tier: 1 GB/month
#
# 8. CLOUDFLARE  (DNS + WAF + DDoS)                 https://dash.cloudflare.com
#    a. Add site → enter your domain
#    b. Change nameservers at your registrar to Cloudflare's
#    c. SSL/TLS → Full (strict)
#    d. Security → WAF → Managed Rules → enable OWASP Core Ruleset
#    e. Free tier: unlimited requests, DDoS protection, WAF
#
# 9. KOYEB  (Deploy back-end + ai-service)           https://app.koyeb.com
#    a. Create 2 services (2 separate free org accounts for free tier):
#       Org 1 → back-end service:
#         - Connect GitHub → select gymeal repo → apps/back-end
#         - Runtime: Docker or .NET buildpack
#         - Port: 5000 → expose publicly
#         - Set all BACKEND env vars (DATABASE_URL, REDIS_URL, etc.)
#       Org 2 → ai-service:
#         - Connect GitHub → select gymeal repo → apps/ai-service
#         - Runtime: Docker or Python buildpack
#         - Port: 8001 → INTERNAL ONLY (do not expose publicly)
#         - Set AI_SERVICE_INTERNAL_URL to Koyeb internal URL
#    b. Free tier: 512 MB RAM, 0.1 vCPU, 1 instance per org
#
# 10. VERCEL  (Deploy front-end)                    https://vercel.com
#     a. Import GitHub repo → set Root Directory: apps/front-end
#     b. Framework: Next.js (auto-detected)
#     c. Add env vars:
#        NEXT_PUBLIC_API_URL=https://<your-koyeb-backend-url>
#        NEXT_PUBLIC_SENTRY_DSN=<your-sentry-dsn>
#     d. Free (Hobby) tier: 100 GB bandwidth/month, unlimited deployments
# ============================================================
