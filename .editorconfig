root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript / JavaScript / JSON / YAML / Markdown
[*.{ts,tsx,js,jsx,json,yaml,yml,md}]
indent_style = space
indent_size = 2

# C#
[*.cs]
indent_style = space
indent_size = 4

# Python
[*.py]
indent_style = space
indent_size = 4

# XML / CSPROJ / SLN
[*.{xml,csproj,props,targets}]
indent_style = space
indent_size = 2

# Makefile
[Makefile]
indent_style = tab
