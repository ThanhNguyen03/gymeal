# Gymeal — Homebrew dependencies (macOS)
# Install everything: brew bundle
# Check what's missing: brew bundle check

# ── Language runtimes ──────────────────────────────────────────────────────────
brew "node"             # Node.js (use .nvmrc to pin version)
brew "python@3.12"      # Python 3.12
cask "dotnet-sdk"       # .NET 8 SDK (C# back-end)

# ── Package managers ──────────────────────────────────────────────────────────
brew "yarn"             # Yarn (enable Yarn 4 via: corepack enable)
brew "poetry"           # Python dependency management

# ── Infrastructure ────────────────────────────────────────────────────────────
brew "docker"           # Docker (for local PostgreSQL + Redis)

# ── Dev tools ─────────────────────────────────────────────────────────────────
brew "git"
brew "jq"               # JSON parsing in shell scripts
brew "openssl"          # For generating JWT keypairs
